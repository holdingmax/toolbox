DATABASE_URL="postgresql://user:password@localhost:5432/toolbox"

# Base de datos "shadow" que usa `prisma migrate dev` para detectar drift al
# generar cada migración nueva. Debe ser una base Postgres separada y vacía
# (en Neon: crear una branch dedicada) — nunca la misma que DATABASE_URL.
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/toolbox_shadow"

# Obligatorio. Mínimo 32 caracteres — el servidor no arranca si falta o es más corto.
# Generar uno seguro con: openssl rand -base64 32
JWT_SECRET="cambiar-en-produccion-por-un-valor-generado-aleatorio-de-32-caracteres-o-mas"
JWT_EXPIRES_IN="8h"
FRONTEND_URL="http://localhost:5173"

# Contraseñas iniciales para los usuarios que crea prisma/seed.ts.
# Sin valor por defecto — el seed aborta si no están seteadas.
SEED_ADMIN_PASSWORD="cambiar-por-una-contraseña-de-desarrollo"
SEED_OPERADOR_PASSWORD="cambiar-por-otra-contraseña-de-desarrollo"

# Resend (envío de emails transaccionales — flujo de "olvidé mi contraseña").
# Obtener la key en https://resend.com — sin dominio propio verificado, Resend
# solo entrega a la casilla con la que se creó la cuenta.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Opcional. Default: "TOOLBOX <onboarding@resend.dev>" (dominio de pruebas de Resend).
MAIL_FROM="TOOLBOX <onboarding@resend.dev>"
