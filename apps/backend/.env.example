DATABASE_URL="postgresql://user:password@localhost:5432/toolbox"

# Obligatorio. Mínimo 32 caracteres — el servidor no arranca si falta o es más corto.
# Generar uno seguro con: openssl rand -base64 32
JWT_SECRET="cambiar-en-produccion-por-un-valor-generado-aleatorio-de-32-caracteres-o-mas"
JWT_EXPIRES_IN="8h"
FRONTEND_URL="http://localhost:5173"

# Contraseñas iniciales para los usuarios que crea prisma/seed.ts.
# Sin valor por defecto — el seed aborta si no están seteadas.
SEED_ADMIN_PASSWORD="cambiar-por-una-contraseña-de-desarrollo"
SEED_OPERADOR_PASSWORD="cambiar-por-otra-contraseña-de-desarrollo"
